# Ensure gradlew always has Unix line endings on all platforms
gradlew        text eol=lf
gradlew.bat    text eol=crlf
*.sh           text eol=lf
*.bat          text eol=crlf
*.yaml         text eol=lf
*.yml          text eol=lf
*.kt           text eol=lf
*.kts          text eol=lf
*.xml          text eol=lf
*.json         text eol=lf
*.md           text eol=lf
*.txt          text eol=lf
*.jar          binary
*.png          binary
*.jpg          binary
*.keystore     binary
*.jks          binary
